<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.web>
    <compilation debug="true" targetFramework="4.7.2" />
    <httpRuntime targetFramework="4.7.2" />
  </system.web>

  <!-- WCF service configuration -->
	<system.serviceModel>
		<services>
			<service name="UnitConverterService.UnitConverterService"
					 behaviorConfiguration="UnitConverterServiceBehavior">
				<endpoint address=""
						  binding="basicHttpBinding"
						  contract="UnitConverterService.IUnitConverterService" />
				<endpoint address="mex"
						  binding="mexHttpBinding"
						  contract="IMetadataExchange" />
			</service>
		</services>
		<behaviors>
			<serviceBehaviors>
				<behavior name="UnitConverterServiceBehavior">
					<serviceMetadata httpGetEnabled="true" />
					<serviceDebug includeExceptionDetailInFaults="true" />
				</behavior>
			</serviceBehaviors>
		</behaviors>
	</system.serviceModel>
</configuration>
